                  }
                },
                "type": "ApiConnection",
                "inputs": {
                  "host": {
                    "connection": {
                      "name": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$connections']['shared_office365']['connectionId']"
                    }
                  },
                  "method": "post",
                  "body": {
                    "MailboxAddress": "myportal@nextant.com",
                    "To": "@variables('ConsultantEmail')",
                    "Subject": "Request rejected",
                    "Body": "<p>Hi @{variables('Consultantname')},<br>\n<br>\n@{variables('DMName')} has rejected your request to work on @{variables('Requestdate')} for @{variables('Hours')} hours.<br>\n<br>\n<br>\nThank you,<br>\nPeople@Nextant</p>",
                    "Importance": "Normal"
                  },
                  "path": "/v2/SharedMailbox/Mail",
                  "authentication": {
                    "type": "Raw",
                    "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
                  }
                }
              }
            }
