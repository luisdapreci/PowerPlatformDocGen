        "Start_and_wait_for_an_approval": {
          "runAfter": {
            "RecordId": [
              "Succeeded"
            ]
          },
          "metadata": {
            "operationMetadataId": "1d92ea73-68e8-4824-aa73-5212ef12694d",
            "flowSystemMetadata": {
              "swaggerOperationId": "StartAndWaitForAnApproval"
            }
          },
          "type": "ApiConnectionWebhook",
          "inputs": {
            "host": {
              "connection": {
                "name": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$connections']['shared_approvals']['connectionId']"
              }
            },
            "body": {
              "notificationUrl": "@{listCallbackUrl()}",
              "title": "You have a new time request",
              "assignedTo": "@{variables('DMEmail')};",
              "details": "Hi @{variables('DMName')},\n\n@{variables('Consultantname')} has requested to work for @{variables('Hours')} hours on @{variables('Requestdate')} for project '@{variables('ProjectName')}'.\nBelow are the comments from the @{variables('Consultantname')} - @{variables('Comments')}  \nPlease approve the request if you agree with it.",
              "enableNotifications": true,
              "enableReassignment": true
            },
            "path": "/types/@{encodeURIComponent('BasicAwaitAll')}/subscriptions",
            "authentication": {
              "type": "Raw",
              "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
            }
          }
        },
        "Condition": {
          "actions": {
