              "metadata": {
                "operationMetadataId": "afc01382-b6a0-4865-b460-2ad59da954f4",
                "flowSystemMetadata": {
                  "swaggerOperationId": "SharedMailboxSendEmailV2"
                }
              },
              "type": "ApiConnection",
              "inputs": {
                "host": {
                  "connection": {
                    "name": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$connections']['shared_office365']['connectionId']"
                  }
                },
                "method": "post",
                "body": {
                  "MailboxAddress": "myportal@nextant.com",
                  "To": "@variables('ConsultantEmail')",
                  "Subject": "Request approved",
                  "Body": "<p>Hi @{variables('Consultantname')},<br>\n<br>\n@{variables('DMName')} has approved your request to work on @{variables('Requestdate')} for @{variables('Hours')} hours.<br>\n<br>\n<br>\nThank you,<br>\nPeople@Nextant</p>",
                  "Importance": "Normal"
                },
                "path": "/v2/SharedMailbox/Mail",
                "authentication": {
                  "type": "Raw",
                  "value": "@json(decodeBase64(triggerOutputs().headers['X-MS-APIM-Tokens']))['$ConnectionKey']"
                }
              }
            }
          },
          "runAfter": {
            "Start_and_wait_for_an_approval": [
              "Succeeded"
            ]
          },
