                  "path": "/datasets/@{encodeURIComponent(encodeURIComponent('https://nextant.sharepoint.com/sites/NextantTeam'))}/tables/@{encodeURIComponent(encodeURIComponent('a83ab7bf-e609-48cd-85f8-95be8161c88e'))}/items/@{encodeURIComponent(variables('RecordId'))}",
